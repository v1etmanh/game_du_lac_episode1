# Lấy API key miễn phí tại https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model dùng để sinh câu trả lời (free tier)
GEMINI_MODEL=gemini-2.5-flash

# Cổng chạy backend
PORT=3001

# Ngưỡng similarity tối thiểu để coi là "liên quan" (0-1).
# Dưới ngưỡng này -> dùng câu fallback có sẵn, không gọi Gemini.
SIMILARITY_THRESHOLD=0.78
